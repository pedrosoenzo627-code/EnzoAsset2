rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function existingData() {
      return resource.data;
    }
    function incomingData() {
      return request.resource.data;
    }
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'pedrosoenzo627@gmail.com'
      );
    }
    function isCreator() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'creator';
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
        && (incomingData().role == 'user' || (incomingData().role == 'admin' && request.auth.token.email == 'pedrosoenzo627@gmail.com'))
        && incomingData().keys().hasAll(['uid', 'email', 'role', 'createdAt'])
        && incomingData().createdAt == request.time;
      allow update: if isOwner(userId)
        && (incomingData().diff(existingData()).affectedKeys().hasOnly(['displayName', 'photoURL']) || isAdmin())
        || isAdmin(); 
    }

    // --- Applications ---
    match /applications/{appId} {
      allow read: if isSignedIn() && (isOwner(existingData().userId) || isAdmin());
      allow create: if isSignedIn() 
        && isOwner(incomingData().userId)
        && incomingData().status == 'pending'
        && incomingData().benefitsAccepted == true
        && incomingData().createdAt == request.time;
      allow update: if isAdmin() 
        && incomingData().diff(existingData()).affectedKeys().hasOnly(['status']);
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true; // Public marketplace
      allow create: if (isCreator() || isAdmin())
        && isOwner(incomingData().creatorId)
        && incomingData().price >= 0
        && incomingData().createdAt == request.time
        && incomingData().name is string && incomingData().name.size() <= 100;
      allow update: if ((isCreator() || isAdmin()) && isOwner(existingData().creatorId) && isOwner(incomingData().creatorId))
        && incomingData().diff(existingData()).affectedKeys().hasOnly(['name', 'description', 'price', 'imageUrl'])
        || isAdmin();
      allow delete: if ((isCreator() || isAdmin()) && isOwner(existingData().creatorId)) || isAdmin();
    }

    // --- Withdrawals ---
    match /withdrawals/{drawId} {
      allow read: if isSignedIn() && (isOwner(existingData().userId) || isAdmin());
      allow create: if isSignedIn() 
        && isOwner(incomingData().userId)
        && incomingData().amount > 0
        && incomingData().status == 'pending'
        && incomingData().createdAt == request.time;
      allow update: if isAdmin()
        && incomingData().diff(existingData()).affectedKeys().hasOnly(['status']);
    }

    // --- Purchases ---
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (isOwner(existingData().userId) || isAdmin());
      allow create: if isSignedIn() 
        && isOwner(incomingData().userId)
        && incomingData().createdAt == request.time;
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
